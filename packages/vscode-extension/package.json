{
  "name": "overmind-vscode-extension",
  "version": "0.1.1",
  "private": true,
  "publisher": "yasdef",
  "type": "module",
  "engines": {
    "vscode": "^1.101.0"
  },
  "main": "./dist/src/extension.js",
  "types": "dist/src/index.d.ts",
  "activationEvents": [
    "onView:overmind.dashboard"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "overmind",
          "title": "Overmind",
          "icon": "media/overmind.svg"
        }
      ]
    },
    "views": {
      "overmind": [
        {
          "id": "overmind.dashboard",
          "name": "Dashboard"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"{src,test}/**/*.ts\" --no-error-on-unmatched-pattern",
    "format:check": "prettier --check \"{src,test}/**/*.ts\" package.json tsconfig.json",
    "test": "npm run build && node --test --experimental-test-coverage \"dist/test/**/*.test.js\""
  },
  "dependencies": {
    "asdlc-coordinator": "0.1.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.101.0"
  }
}
