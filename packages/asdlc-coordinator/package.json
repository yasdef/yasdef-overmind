{
  "name": "asdlc-coordinator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "overmind": "dist/overmind.js"
  },
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && esbuild src/bin/overmind.ts --bundle --platform=node --format=esm --outfile=dist/overmind.js && chmod +x dist/overmind.js",
    "test": "npm run build && node --test \"dist/test/**/*.test.js\""
  },
  "dependencies": {}
}
