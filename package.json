{
  "name": "yasdef-overmind",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "setup": "node packages/installer/dist/src/bin/overmind.js init",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format:check": "npm run format:check --workspaces --if-present && prettier --check package.json tsconfig.base.json eslint.config.js .prettierrc.json",
    "test": "npm run test:ts",
    "test:ts": "npm run test --workspaces --if-present",
    "verify": "npm run typecheck && npm run lint && npm run format:check && npm run build && npm test"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.4",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.62.1"
  }
}
